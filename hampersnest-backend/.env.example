# Server Configurations
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hampersnest
JWT_SECRET=super_secret_jwt_key_here

# Cloudflare R2 Object Storage Configuration (For Image Uploads)
# Create an API token in Cloudflare dashboard with R2 Read/Write permissions
R2_ACCESS_KEY_ID=your_cloudflare_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_cloudflare_r2_secret_access_key

# R2 Endpoint URL (Find this in your Cloudflare R2 Bucket settings)
# Example: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com

# Name of your R2 Bucket
R2_BUCKET_NAME=hampersnest-images

# Public Custom Domain or Dev subdomain to access R2 bucket objects via HTTP
# Example: https://pub-xxxxxx.r2.dev or https://images.hampersnest.com
R2_PUBLIC_URL=https://your_r2_public_domain_or_dev_subdomain
